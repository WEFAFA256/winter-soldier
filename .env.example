# DPO Pay Configuration
# Get these from your DPO Pay dashboard: https://dpogroup.com

# Your DPO Company Token (looks like: 57466282-EBD7-4ED5-B699-8659330A4660)
DPO_COMPANY_TOKEN=YOUR_DPO_COMPANY_TOKEN

# Your DPO Service Type ID (looks like: 3854)
DPO_SERVICE_TYPE=YOUR_DPO_SERVICE_TYPE

# Note: Copy this file to .env and fill in your actual credentials
# Never commit .env to version control!
